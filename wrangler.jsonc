cat > wrangler.jsonc << 'EOF'
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-pico3",
  "compatibility_date": "2026-06-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "GITHUB_TOKEN": "你的GitHub_Token",
    "GITHUB_USER": "chnbsdan",
    "GITHUB_REPO": "cf-pico"
  }
}
EOF
